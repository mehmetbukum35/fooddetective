<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- User-selectable UI preferences and sync cache are recreated safely. -->
    <exclude domain="sharedpref" path="app_language_preferences.xml" />
    <exclude domain="sharedpref" path="app_theme_preferences.xml" />
    <exclude domain="sharedpref" path="additives_sync_prefs.xml" />

    <!-- Local additive data can be restored from the bundled asset or remote API. -->
    <exclude domain="database" path="food_detective_database" />
    <exclude domain="database" path="food_detective_database-shm" />
    <exclude domain="database" path="food_detective_database-wal" />
</full-backup-content>
