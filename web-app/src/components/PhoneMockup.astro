---
const { lang = 'en' } = Astro.props;
const t = lang === 'tr'
  ? {
      top: 'OCR · LATIN · CİHAZ İÇİ',
      live: 'TARANIYOR',
      lead: 'İçindekiler',
      textA: 'buğday unu, şeker, bitkisel yağ, glikoz-fruktoz şurubu, kabartıcı, emülgatör, asitlik düzenleyici',
      textB: 'renklendirici',
      textC: 'lezzet artırıcı',
      textD: 'koruyucu, aroma vericiler. Fındık ve süt içerebilir.',
      read: 'çözülen kanıt',
      status: 'eşleşme bulundu',
      e330: 'Sitrik Asit',
      e120: 'Karmin',
      e621: 'MSG',
      acid: 'Asitlik düzenleyici',
      color: 'Renklendirici',
      flavor: 'Lezzet artırıcı',
      halal: 'Helal',
      doubtful: 'Şüpheli'
    }
  : {
      top: 'OCR · LATIN · ON DEVICE',
      live: 'SCANNING',
      lead: 'Ingredients',
      textA: 'wheat flour, sugar, vegetable oil, glucose-fructose syrup, raising agent, emulsifier, acidity regulator',
      textB: 'colour additive',
      textC: 'flavour enhancer',
      textD: 'preservative, flavourings. May contain hazelnut and milk.',
      read: 'decoded evidence',
      status: 'match found',
      e330: 'Citric Acid',
      e120: 'Carmine',
      e621: 'MSG',
      acid: 'Acidity regulator',
      color: 'Colour additive',
      flavor: 'Flavour enhancer',
      halal: 'Halal',
      doubtful: 'Doubtful'
    };
---
<div class="phone-stage" aria-hidden="true">
  <div class="orbit"></div>
  <section class="detective-scanner">
    <div class="scanner-top">
      <span>{t.top}</span>
      <span class="live-dot">{t.live}</span>
    </div>
    <div class="ocr-frame">
      <p class="ingredients">
        <span class="lead">{t.lead}</span>
        {t.textA} (<span class="tok">E330</span>), {t.textB} (<span class="tok">E120</span>), {t.textC} (<span class="tok">E621</span>), {t.textD}
      </p>
      <div class="scanline"></div>
    </div>
    <div class="readout">
      <span>{t.read} → <b>E330 · E120 · E621</b></span>
      <span>{t.status}</span>
    </div>
    <div class="evidence">
      <div class="ev">
        <div class="code">E330</div>
        <div class="nm">{t.e330}<small>{t.acid}</small></div>
        <div><span class="pill ok">{t.halal}</span><span class="risk-bars"><i></i><i></i><i></i></span></div>
      </div>
      <div class="ev">
        <div class="code">E120</div>
        <div class="nm">{t.e120}<small>{t.color}</small></div>
        <div><span class="pill warn">{t.doubtful}</span><span class="risk-bars"><i></i><i></i><i></i></span></div>
      </div>
      <div class="ev">
        <div class="code">E621</div>
        <div class="nm">{t.e621}<small>{t.flavor}</small></div>
        <div><span class="pill ok">{t.halal}</span><span class="risk-bars"><i></i><i></i><i></i></span></div>
      </div>
    </div>
  </section>
</div>
