---
const { lang = 'tr' } = Astro.props;
const t = lang === 'tr'
  ? {
      chip: 'Canlı Etiket Okuma',
      search: 'E120 · Karmin',
      title: 'Karmin',
      desc: 'Böcek kaynaklı kırmızı renklendirici. Helal hassasiyeti olan tüketiciler için sakıncalıdır.',
      halal: 'Haram',
      risk: 'Orta Risk',
      ocr: 'OCR cihazda çalışır'
    }
  : {
      chip: 'Live Label Scan',
      search: 'E120 · Carmine',
      title: 'Carmine',
      desc: 'An insect-derived red colour additive. Unsuitable for consumers with halal concerns.',
      halal: 'Not halal',
      risk: 'Medium risk',
      ocr: 'On-device OCR'
    };
---
<div class="phone-stage" aria-hidden="true">
  <div class="orbit"></div>
  <div class="phone">
    <div class="phone-screen">
      <span class="scan-chip">⌁ {t.chip}</span>
      <div class="search-box">{t.search}</div>
      <div class="result-card">
        <h3>{t.title}</h3>
        <p>{t.desc}</p>
        <div class="bars"><span></span><span></span><span></span></div>
        <div class="tag-row">
          <span class="tag red">{t.halal}</span>
          <span class="tag">{t.risk}</span>
          <span class="tag green">{t.ocr}</span>
        </div>
      </div>
      <div class="result-card">
        <h3>E330</h3>
        <p>{lang === 'tr' ? 'Sitrik asit gibi yaygın katkıları kod veya ad ile hızlıca arayın.' : 'Quickly search common additives such as citric acid by code or name.'}</p>
        <div class="tag-row">
          <span class="tag green">{lang === 'tr' ? 'Arama' : 'Search'}</span>
          <span class="tag green">{lang === 'tr' ? 'Çevrimdışı veri' : 'Offline data'}</span>
        </div>
      </div>
    </div>
  </div>
</div>
