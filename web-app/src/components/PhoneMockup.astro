---
const { lang = 'en' } = Astro.props;
const t = lang === 'tr'
  ? {
      chip: 'Canlı Etiket Okuma',
      search: 'karmin · E120 · renklendirici',
      title: 'Karmin',
      desc: 'Kod, ad, takma ad veya işlev sınıfı ile bulunan katkı maddesi sonucu.',
      halal: 'Haram',
      risk: 'Orta Risk',
      ocr: 'Ad + kod eşleşmesi',
      smart: 'Akıllı eşleştirme',
      smartText: 'OCR yalnızca E-kodu değil; katkı adlarını ve takma adları da yakalamaya çalışır.'
    }
  : {
      chip: 'Live Label Scan',
      search: 'carmine · E120 · colour',
      title: 'Carmine',
      desc: 'A result found by code, additive name, alias, or functional class.',
      halal: 'Not halal',
      risk: 'Medium risk',
      ocr: 'Name + code match',
      smart: 'Smart matching',
      smartText: 'OCR does not only look for E-codes; it also tries to match additive names and aliases.'
    };
---
<div class="phone-stage" aria-hidden="true">
  <div class="orbit"></div>
  <span class="float-token one">name fields</span>
  <span class="float-token two">aliases</span>
  <span class="float-token three">range codes</span>
  <div class="phone">
    <div class="phone-screen">
      <span class="scan-chip">⌁ {t.chip}</span>
      <div class="search-box">{t.search}</div>
      <div class="suggestion-stack">
        <div class="suggestion-mini"><b>E120</b><span>{lang === 'tr' ? 'Karmin' : 'Carmine'}</span></div>
        <div class="suggestion-mini"><b>E160A</b><span>{lang === 'tr' ? 'Beta karoten' : 'Beta carotene'}</span></div>
        <div class="suggestion-mini"><b>E330</b><span>{lang === 'tr' ? 'Sitrik asit' : 'Citric acid'}</span></div>
      </div>
      <div class="result-card">
        <h3>{t.title}</h3>
        <p>{t.desc}</p>
        <div class="bars"><span></span><span></span><span></span></div>
        <div class="tag-row">
          <span class="tag red">{t.halal}</span>
          <span class="tag">{t.risk}</span>
          <span class="tag green">{t.ocr}</span>
        </div>
      </div>
      <div class="result-card">
        <h3>{t.smart}</h3>
        <p>{t.smartText}</p>
      </div>
    </div>
  </div>
</div>
